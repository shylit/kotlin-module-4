package com.example.module4_ex11.alarm


import android.app.AlarmManager
import android.app.PendingIntent
import android.content.Context
import android.content.Intent
import android.os.Build
import java.util.Calendar

object ReminderScheduler {
    private const val REQ_CODE = 2001

    fun enable(context: Context): Long {
        val triggerAt = nearest20_00Millis()
        scheduleExact(context, triggerAt)

        ReminderPrefs.setEnabled(context, true)
        ReminderPrefs.setNextTimeMillis(context, triggerAt)
        return triggerAt
    }

    fun disable(context: Context) {
        cancel(context)
        ReminderPrefs.setEnabled(context, false)
        ReminderPrefs.setNextTimeMillis(context, 0L)
    }

    fun rescheduleIfEnabled(context: Context) {
        if (!ReminderPrefs.isEnabled(context)) return
        val triggerAt = nearest20_00Millis()
        scheduleExact(context, triggerAt)
        ReminderPrefs.setNextTimeMillis(context, triggerAt)
    }

    fun scheduleNextDay(context: Context) {
        val cal = Calendar.getInstance().apply {
            timeInMillis = System.currentTimeMillis()
            add(Calendar.DAY_OF_YEAR, 1)
            set(Calendar.HOUR_OF_DAY, 20)
            set(Calendar.MINUTE, 0)
            set(Calendar.SECOND, 0)
            set(Calendar.MILLISECOND, 0)
        }
        val triggerAt = cal.timeInMillis
        scheduleExact(context, triggerAt)
        ReminderPrefs.setNextTimeMillis(context, triggerAt)
    }

    private fun scheduleExact(context: Context, triggerAtMillis: Long) {
        val am = context.getSystemService(Context.ALARM_SERVICE) as AlarmManager
        val pi = pendingIntent(context)
        am.setExactAndAllowWhileIdle(AlarmManager.RTC_WAKEUP, triggerAtMillis, pi)
    }

    private fun cancel(context: Context) {
        val am = context.getSystemService(Context.ALARM_SERVICE) as AlarmManager
        am.cancel(pendingIntent(context))
    }

    private fun pendingIntent(context: Context): PendingIntent {
        val intent = Intent(context, ReminderReceiver::class.java)
        val flags = PendingIntent.FLAG_UPDATE_CURRENT or
                (if (Build.VERSION.SDK_INT >= Build.VERSION_CODES.M) PendingIntent.FLAG_IMMUTABLE else 0)
        return PendingIntent.getBroadcast(context, REQ_CODE, intent, flags)
    }

    private fun nearest20_00Millis(): Long {
        val now = Calendar.getInstance()
        val cal = Calendar.getInstance().apply {
            set(Calendar.HOUR_OF_DAY, 20)
            set(Calendar.MINUTE, 0) //удалить эту и верхнюю = add(Calendar.MINUTE, 1)
            set(Calendar.SECOND, 0)
            set(Calendar.MILLISECOND, 0)
        }
        if (now.timeInMillis >= cal.timeInMillis) {
            cal.add(Calendar.DAY_OF_YEAR, 1)
        }
        return cal.timeInMillis
    }
}

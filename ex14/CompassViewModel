package com.example.module4_ex14

import android.app.Application
import android.content.Context
import android.hardware.Sensor
import android.hardware.SensorEvent
import android.hardware.SensorEventListener
import android.hardware.SensorManager
import androidx.lifecycle.AndroidViewModel
import kotlinx.coroutines.flow.MutableStateFlow
import kotlinx.coroutines.flow.StateFlow
import kotlin.math.roundToInt

class CompassViewModel(app: Application) : AndroidViewModel(app), SensorEventListener {

    private val sensorManager =
        app.getSystemService(Context.SENSOR_SERVICE) as SensorManager

    // Состояния для UI
    private val _azimuthDeg = MutableStateFlow(0f)
    val azimuthDeg: StateFlow<Float> = _azimuthDeg

    private val _hasSensor = MutableStateFlow(true)
    val hasSensor: StateFlow<Boolean> = _hasSensor

    // --- Сенсоры ---
    private val rotationVector: Sensor? =
        sensorManager.getDefaultSensor(Sensor.TYPE_ROTATION_VECTOR)

    private val accel: Sensor? =
        sensorManager.getDefaultSensor(Sensor.TYPE_ACCELEROMETER)

    private val magnet: Sensor? =
        sensorManager.getDefaultSensor(Sensor.TYPE_MAGNETIC_FIELD)

    // Данные для запасного варианта (accel + magnet)
    private val accelValues = FloatArray(3)
    private val magnetValues = FloatArray(3)
    private var hasAccel = false
    private var hasMagnet = false

    private var isStarted = false

    fun start() {
        if (isStarted) return
        isStarted = true

        // Проверка: что есть на устройстве
        val canUseRotationVector = rotationVector != null
        val canUseFallback = (accel != null && magnet != null)

        if (!canUseRotationVector && !canUseFallback) {
            _hasSensor.value = false
            return
        } else {
            _hasSensor.value = true
        }

        // Подписываемся
        val rate = SensorManager.SENSOR_DELAY_UI

        if (canUseRotationVector) {
            sensorManager.registerListener(this, rotationVector, rate)
        } else {
            // запасной вариант
            sensorManager.registerListener(this, accel, rate)
            sensorManager.registerListener(this, magnet, rate)
        }
    }

    fun stop() {
        if (!isStarted) return
        isStarted = false
        sensorManager.unregisterListener(this)
        hasAccel = false
        hasMagnet = false
    }

    override fun onCleared() {
        stop()
        super.onCleared()
    }

    override fun onAccuracyChanged(sensor: Sensor?, accuracy: Int) = Unit

    override fun onSensorChanged(event: SensorEvent) {
        when (event.sensor.type) {

            Sensor.TYPE_ROTATION_VECTOR -> {
                val rotationMatrix = FloatArray(9)
                SensorManager.getRotationMatrixFromVector(rotationMatrix, event.values)

                val orientation = FloatArray(3)
                SensorManager.getOrientation(rotationMatrix, orientation)

                // orientation[0] = azimuth в радианах
                val azimuthRad = orientation[0]
                val deg = Math.toDegrees(azimuthRad.toDouble()).toFloat()
                _azimuthDeg.value = normalize0to360(deg)
            }

            Sensor.TYPE_ACCELEROMETER -> {
                System.arraycopy(event.values, 0, accelValues, 0, 3)
                hasAccel = true
                tryComputeFallbackAzimuth()
            }

            Sensor.TYPE_MAGNETIC_FIELD -> {
                System.arraycopy(event.values, 0, magnetValues, 0, 3)
                hasMagnet = true
                tryComputeFallbackAzimuth()
            }
        }
    }

    private fun tryComputeFallbackAzimuth() {
        if (!hasAccel || !hasMagnet) return

        val rotationMatrix = FloatArray(9)
        val ok = SensorManager.getRotationMatrix(rotationMatrix, null, accelValues, magnetValues)
        if (!ok) return

        val orientation = FloatArray(3)
        SensorManager.getOrientation(rotationMatrix, orientation)

        val azimuthRad = orientation[0]
        val deg = Math.toDegrees(azimuthRad.toDouble()).toFloat()
        _azimuthDeg.value = normalize0to360(deg)
    }

    private fun normalize0to360(deg: Float): Float {
        var d = deg % 360f
        if (d < 0f) d += 360f
        return d
    }

    fun azimuthText(): String {
        val rounded = azimuthDeg.value.roundToInt()
        return "Азимут: $rounded°"
    }
}

package com.example.module4_ex7

import android.app.Service
import android.content.Intent
import android.os.Binder
import android.os.IBinder
import kotlinx.coroutines.*
import kotlinx.coroutines.flow.MutableStateFlow
import kotlinx.coroutines.flow.StateFlow
import kotlin.random.Random

class RandomNumberService : Service() {

    // Binder — “ручка”, через которую Activity получит ссылку на сервис
    inner class LocalBinder : Binder() {
        fun getService(): RandomNumberService = this@RandomNumberService
    }

    private val binder = LocalBinder()

    // Последнее число (его будет читать UI)
    private val _number = MutableStateFlow<Int?>(null)
    val number: StateFlow<Int?> = _number

    private val scope = CoroutineScope(SupervisorJob() + Dispatchers.Default)
    private var job: Job? = null
    private var boundClients = 0

    override fun onBind(intent: Intent?): IBinder {
        boundClients++
        startGeneratingIfNeeded()
        return binder
    }

    override fun onUnbind(intent: Intent?): Boolean {
        boundClients--
        if (boundClients <= 0) {
            stopGenerating()
            stopSelf()
        }
        return super.onUnbind(intent)
    }

    private fun startGeneratingIfNeeded() {
        if (job != null) return

        job = scope.launch {
            while (isActive) {
                _number.value = Random.nextInt(0, 101) // 0..100
                delay(1000)
            }
        }
    }

    private fun stopGenerating() {
        job?.cancel()
        job = null
        _number.value = null
    }

    override fun onDestroy() {
        stopGenerating()
        scope.cancel()
        super.onDestroy()
    }
}
